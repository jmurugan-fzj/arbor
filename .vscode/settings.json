{
    // Point the C/C++ extension to the compile database generated by CMake
    "C_Cpp.default.compileCommands": "${workspaceFolder}/build-debug/compile_commands.json",

    // CMake‑Tools: tell it where to run CMake
    "cmake.sourceDirectory": "${workspaceFolder}",
    "cmake.buildDirectory": "${workspaceFolder}/build-debug",

    // Always configure for Debug when we press the CMake status‑bar button
    "cmake.configureOnOpen": true,
    "cmake.preferredGenerators": [
        "Ninja"
    ],

    // Optional: if you use clang‑tools, set the path to the compiler
    // "C_Cpp.default.compilerPath": "/usr/bin/clang++"
}